# NVIDIA Audio2Face upstream scaffold

# Path to the unpacked NVIDIA Audio2Face-3D SDK directory on the GPU machine.
NVIDIA_A2F_SDK_ROOT=

# Path to the chosen Audio2Face model.json or equivalent model entry file.
NVIDIA_A2F_MODEL_PATH=

# Directory where prepared WAV artifacts should be written.
NVIDIA_A2F_ARTIFACTS_DIR=./artifacts

# Directory where each NVIDIA execution request/result folder should be written.
NVIDIA_A2F_OUTPUTS_DIR=./outputs

# Audio format to prepare for NVIDIA Audio2Face examples.
NVIDIA_A2F_SAMPLE_RATE=16000

# Keep true for the intended production path.
NVIDIA_A2F_USE_GPU_SOLVER=true

# Turn on only after you have a real bridge command that accepts the prepared WAV.
NVIDIA_A2F_ENABLE_EXECUTION=false

# Command template used to invoke your NVIDIA bridge.
# Available placeholders:
# {sdk_root} {model_path} {audio_path} {output_dir} {manifest_path}
# {session_id} {utterance} {sample_rate} {use_gpu_solver}
# Example:
# NVIDIA_A2F_RUN_COMMAND=./bridge/run_bridge.sh --audio {audio_path} --model {model_path} --output {output_dir} --session {session_id} --utterance {utterance}
NVIDIA_A2F_RUN_COMMAND=

# Timeout for one NVIDIA execution.
NVIDIA_A2F_RUN_TIMEOUT_SECONDS=180

# Optional server-side TTS to create real speech WAV files before NVIDIA inference.
NVIDIA_A2F_ELEVENLABS_API_KEY=
NVIDIA_A2F_ELEVENLABS_VOICE_ID=
