# NVIDIA Audio2Face upstream scaffold

# Path to the unpacked NVIDIA Audio2Face-3D SDK directory on the GPU machine.
NVIDIA_A2F_SDK_ROOT=

# Path to the chosen Audio2Face model.json or equivalent model entry file.
NVIDIA_A2F_MODEL_PATH=

# Directory where prepared WAV artifacts should be written.
NVIDIA_A2F_ARTIFACTS_DIR=./artifacts

# Audio format to prepare for NVIDIA Audio2Face examples.
NVIDIA_A2F_SAMPLE_RATE=16000

# Keep true for the intended production path.
NVIDIA_A2F_USE_GPU_SOLVER=true

# Optional server-side TTS to create real speech WAV files before NVIDIA inference.
NVIDIA_A2F_ELEVENLABS_API_KEY=
NVIDIA_A2F_ELEVENLABS_VOICE_ID=
