# Exact-style env template for the Pocket Twin Runpod pod layout used in this repo.
# Assumes:
# - repo checkout: /workspace/pocket-twin
# - LivePortrait checkout: /workspace/LivePortrait
# - generated videos copied to: /workspace/liveportrait-results
# - those files are exposed by your own static host or reverse proxy

LIVEPORTRAIT_INFERENCE_SCRIPT=/workspace/pocket-twin/liveportrait-runpod-worker/your_infer.py
LIVEPORTRAIT_BASE_COMMAND=python /workspace/LivePortrait/inference.py
LIVEPORTRAIT_SOURCE_ARG=--source
LIVEPORTRAIT_DRIVING_ARG=--driving
LIVEPORTRAIT_MOTION_ARG=--motion-template
LIVEPORTRAIT_OUTPUT_ARG=--output
LIVEPORTRAIT_MODE_ARG=--mode
LIVEPORTRAIT_PUBLIC_RESULTS_DIR=/workspace/liveportrait-results
LIVEPORTRAIT_PUBLIC_BASE_URL=https://ukwj8sd7k5tutx-8000.proxy.runpod.net/results

# If your LivePortrait entrypoint already supports lip-only mode, keep this.
# Otherwise remove it and inject the mode through LIVEPORTRAIT_INFER_COMMAND_TEMPLATE instead.
LIVEPORTRAIT_RESULT_URL_TEMPLATE=https://YOUR-RUNPOD-HOST/results/{output_video_name}
LIVEPORTRAIT_UPLOAD_COMMAND_TEMPLATE=python /workspace/pocket-twin/liveportrait-runpod-worker/examples/upload_result.py {output_video_path}

# Optional if your command differs from the arg-based builder above:
# LIVEPORTRAIT_INFER_COMMAND_TEMPLATE=python /workspace/LivePortrait/inference.py --source {source_image_path} --driving {driving_video_path} --output {output_video_path} --mode {live_portrait_mode}
