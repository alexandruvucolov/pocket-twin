# Runpod worker env for invoking LivePortrait through Docker
# Assumes the host/container already has docker available.

LIVEPORTRAIT_INFERENCE_SCRIPT=/workspace/liveportrait-runpod-worker/your_infer.py

# This command is formatted by your_infer.py with runtime paths.
LIVEPORTRAIT_INFER_COMMAND_TEMPLATE=docker run --rm -v /tmp:/tmp -v /workspace:/workspace YOUR_LIVEPORTRAIT_IMAGE python /app/inference.py --source {source_image_path} --driving {driving_video_path} --output {output_video_path} --mode {live_portrait_mode}

# If the result lands in a location already served publicly:
LIVEPORTRAIT_RESULT_URL_TEMPLATE=https://YOUR-HOST/results/{output_video_name}

# Or instead upload after generation by printing a URL to stdout:
# LIVEPORTRAIT_UPLOAD_COMMAND_TEMPLATE=python /workspace/upload_result.py {output_video_path}

LIVE_AVATAR_LIVEPORTRAIT_MODE=lips-only
LIVE_AVATAR_LIVEPORTRAIT_PRESERVE_HEAD_POSE=true
LIVE_AVATAR_LIVEPORTRAIT_PRESERVE_EYE_GAZE=true
LIVE_AVATAR_LIVEPORTRAIT_NORMALIZE_LIPS=true
LIVE_AVATAR_LIVEPORTRAIT_DEFAULT_INPUT_JSON={"retarget_module":"R_lip","animation_region":"lips"}
