# Runpod worker env for a typical checked-out LivePortrait repo
# Adjust the command/flags to match your exact repo version.

LIVEPORTRAIT_INFERENCE_SCRIPT=/workspace/liveportrait-runpod-worker/your_infer.py

# Example: official-style Python entrypoint living in /workspace/LivePortrait
LIVEPORTRAIT_BASE_COMMAND=python /workspace/LivePortrait/inference.py
LIVEPORTRAIT_SOURCE_ARG=--source
LIVEPORTRAIT_DRIVING_ARG=--driving
LIVEPORTRAIT_MOTION_ARG=--motion-template
LIVEPORTRAIT_OUTPUT_ARG=--output
LIVEPORTRAIT_MODE_ARG=--mode

# If your script writes directly into a mounted public folder, use a static URL template.
LIVEPORTRAIT_RESULT_URL_TEMPLATE=https://YOUR-HOST/results/{output_video_name}

# Lip-only defaults
LIVE_AVATAR_LIVEPORTRAIT_MODE=lips-only
LIVE_AVATAR_LIVEPORTRAIT_PRESERVE_HEAD_POSE=true
LIVE_AVATAR_LIVEPORTRAIT_PRESERVE_EYE_GAZE=true
LIVE_AVATAR_LIVEPORTRAIT_NORMALIZE_LIPS=true
LIVE_AVATAR_LIVEPORTRAIT_DEFAULT_INPUT_JSON={"retarget_module":"R_lip","animation_region":"lips"}
