rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/photo.jpg {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/avatars/{avatarId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // AI-generated media written by the Modal backend worker
    match /generated/{fileName} {
      allow read: if true;
      allow write: if true;
    }
  }
}
