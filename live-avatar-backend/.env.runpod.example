# Pocket Twin Runpod backend env example
# Copy to: /workspace/pocket-twin/live-avatar-backend/.env

# TURN / ICE (fill one strategy)
LIVE_AVATAR_ICE_SERVERS_JSON=
# or use manual STUN/TURN below
LIVE_AVATAR_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
LIVE_AVATAR_TURN_URLS=
LIVE_AVATAR_TURN_USERNAME=
LIVE_AVATAR_TURN_CREDENTIAL=

# Audio2Face chain
LIVE_AVATAR_A2F_SERVICE_URL=http://127.0.0.1:8010
LIVE_AVATAR_A2F_API_KEY=
LIVE_AVATAR_A2F_AVATAR_ID=default-avatar

# Runpod LivePortrait worker / endpoint
LIVE_AVATAR_RUNPOD_API_KEY=
LIVE_AVATAR_RUNPOD_LIVEPORTRAIT_ENDPOINT_ID=
LIVE_AVATAR_RUNPOD_BASE_URL=https://api.runpod.ai/v2
LIVE_AVATAR_DRIVING_VIDEO_URL=
LIVE_AVATAR_LIVEPORTRAIT_MOTION_TEMPLATE_URL=
LIVE_AVATAR_LIVEPORTRAIT_MODE=lips-only
LIVE_AVATAR_LIVEPORTRAIT_PRESERVE_HEAD_POSE=true
LIVE_AVATAR_LIVEPORTRAIT_PRESERVE_EYE_GAZE=true
LIVE_AVATAR_LIVEPORTRAIT_NORMALIZE_LIPS=true
LIVE_AVATAR_LIVEPORTRAIT_DEFAULT_INPUT_JSON={"retarget_module":"R_lip","animation_region":"lips"}
LIVE_AVATAR_PUBLIC_RESULTS_DIR=/workspace/liveportrait-results
