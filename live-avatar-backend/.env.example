# Copy this file to .env inside live-avatar-backend/

# ── MuseTalk lip-sync (replaces TPS pixel warp with neural inpainting) ──────
# When both keys are set the backend calls ElevenLabs to generate audio,
# runs MuseTalk inference, and streams the resulting lip-sync frames over WebRTC.
# Requires MuseTalk to be installed at /workspace/MuseTalk (see README).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Optional: override MuseTalk installation path (default: /workspace/MuseTalk)
MUSETALK_DIR=

# Option 0: explicit ICE server array JSON (preferred when your provider gives you a ready-made array)
LIVE_AVATAR_ICE_SERVERS_JSON=

# Optional: external Audio2Face adapter service sitting in front of NVIDIA Audio2Face / ACE
LIVE_AVATAR_A2F_SERVICE_URL=
LIVE_AVATAR_A2F_API_KEY=
LIVE_AVATAR_A2F_AVATAR_ID=default-avatar

# Optional: Runpod LivePortrait clip generation for higher-quality live avatar sessions
LIVE_AVATAR_RUNPOD_API_KEY=
LIVE_AVATAR_RUNPOD_LIVEPORTRAIT_ENDPOINT_ID=
LIVE_AVATAR_RUNPOD_BASE_URL=https://api.runpod.ai/v2
LIVE_AVATAR_DRIVING_VIDEO_URL=
LIVE_AVATAR_LIVEPORTRAIT_MOTION_TEMPLATE_URL=
LIVE_AVATAR_LIVEPORTRAIT_MODE=
LIVE_AVATAR_LIVEPORTRAIT_PRESERVE_HEAD_POSE=
LIVE_AVATAR_LIVEPORTRAIT_PRESERVE_EYE_GAZE=
LIVE_AVATAR_LIVEPORTRAIT_NORMALIZE_LIPS=
LIVE_AVATAR_LIVEPORTRAIT_DEFAULT_INPUT_JSON=

# Option A: Metered automatic TURN credentials
LIVE_AVATAR_METERED_DOMAIN=yourappname.metered.live
LIVE_AVATAR_METERED_API_KEY=your_metered_api_key
LIVE_AVATAR_METERED_REGION=
LIVE_AVATAR_METERED_API_BASE_URL=
LIVE_AVATAR_METERED_INSECURE_TLS=false

# Option B: manual STUN/TURN
LIVE_AVATAR_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
LIVE_AVATAR_TURN_URLS=turn:YOUR_TURN_HOST:3478?transport=udp,turn:YOUR_TURN_HOST:3478?transport=tcp
LIVE_AVATAR_TURN_USERNAME=YOUR_USERNAME
LIVE_AVATAR_TURN_CREDENTIAL=YOUR_PASSWORD
