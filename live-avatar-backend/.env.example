# Copy this file to .env inside live-avatar-backend/

# Option 0: explicit ICE server array JSON (preferred when your provider gives you a ready-made array)
LIVE_AVATAR_ICE_SERVERS_JSON=

# Option A: Metered automatic TURN credentials
LIVE_AVATAR_METERED_DOMAIN=yourappname.metered.live
LIVE_AVATAR_METERED_API_KEY=your_metered_api_key
LIVE_AVATAR_METERED_REGION=
LIVE_AVATAR_METERED_API_BASE_URL=
LIVE_AVATAR_METERED_INSECURE_TLS=false

# Option B: manual STUN/TURN
LIVE_AVATAR_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
LIVE_AVATAR_TURN_URLS=turn:YOUR_TURN_HOST:3478?transport=udp,turn:YOUR_TURN_HOST:3478?transport=tcp
LIVE_AVATAR_TURN_USERNAME=YOUR_USERNAME
LIVE_AVATAR_TURN_CREDENTIAL=YOUR_PASSWORD
